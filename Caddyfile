:8080 {
	root * /srv
	encode zstd gzip

	redir /game /game/
	redir /games /games/

	handle_path /game/* {
		root * /game
		file_server
	}

	handle_path /games/* {
		root * /games
		file_server
	}

	@root path /
	rewrite @root /status.html

	header {
		Cache-Control "no-store"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "no-referrer"
	}

	file_server
}
